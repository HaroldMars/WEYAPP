# ===== SERVER =====
PORT=5000
NODE_ENV=development

# ===== DATABASE =====
# Local: mongodb://localhost:27017/chatapp
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chatapp
MONGO_URI=mongodb://localhost:27017/chatapp

# ===== JWT =====
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ===== CLIENT URL (for CORS + email links) =====
CLIENT_URL=http://localhost:5173

# ===== EMAIL (Gmail SMTP example) =====
# Use a Gmail "App Password", NOT your real Gmail password.
# Create one at: https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM="ChatApp <your_email@gmail.com>"

# ===== FILE UPLOADS =====
# "local" stores files on the server's disk (uploads/ folder) - fine for a single server / VPS.
# "cloudinary" stores files in the cloud - required if you deploy backend to Render/Railway
# with an ephemeral filesystem, since local files get wiped on every redeploy/restart.
UPLOAD_STRATEGY=local

# Only needed if UPLOAD_STRATEGY=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
